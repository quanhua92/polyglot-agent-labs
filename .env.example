# Polyglot Agent Labs - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API Keys
# =============================================================================

OPENAI_API_KEY=sk-xxxx...
ANTHROPIC_API_KEY=sk-ant-xxxx...
OPENROUTER_API_KEY=sk-or-xxxx...

# =============================================================================
# Optional: Other providers
# =============================================================================

# GOOGLE_API_KEY=...
# COHERE_API_KEY=...
# MISTRAL_API_KEY=...

# =============================================================================
# Logging
# =============================================================================

# Set to "debug" for verbose output, "info" for normal, "warn" or "error" for quiet
AGENT_LOG_LEVEL=info
